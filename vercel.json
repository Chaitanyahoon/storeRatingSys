{
  "framework": "vite",
  "buildCommand": "cd frontend && npm install --include=dev && npm run build",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://storeratingsys.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
